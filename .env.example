# ============================================================
# Job Alert CV Optimizer - Environment Configuration
# ============================================================
# Copy to .env and fill in values. All real connectors are OFF by default.

# --- Core ---
DATABASE_URL=sqlite:///./job_alert.db

# --- Feature Flags ---
ENABLE_REAL_NOTIFICATIONS=false
ENABLE_REAL_GOOGLE_DOCS=false
ENABLE_REAL_TELEGRAM_INGEST=false
ENABLE_QUEUE_NOTIFICATIONS=false
ENABLE_LLM_RERANKER=false

# --- Queue Worker ---
QUEUE_MAX_ATTEMPTS=3
QUEUE_BASE_BACKOFF_SECONDS=60
QUEUE_MAX_BACKOFF_SECONDS=3600

# --- LLM Reranker ---
OPENAI_API_KEY=
LLM_RERANKER_MODEL=gpt-4o-mini
# Or use Anthropic:
ANTHROPIC_API_KEY=
LLM_RERANKER_MODEL_ANTHROPIC=claude-3-haiku-20240307

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_SOURCE_CHAT_ID=

# --- Email (SendGrid) ---
SENDGRID_API_KEY=
ALERT_FROM_EMAIL=alerts@example.com

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- WhatsApp (Meta Cloud API) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- Google Docs ---
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
GOOGLE_DOC_SHARE_WITH=
