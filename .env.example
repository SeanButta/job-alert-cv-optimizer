APP_ENV=dev
DATABASE_URL=sqlite:///./job_alert.db

# Connectors toggles
ENABLE_REAL_NOTIFICATIONS=false
ENABLE_REAL_GOOGLE_DOCS=false
ENABLE_REAL_TELEGRAM_INGEST=false

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_SOURCE_CHAT_ID=

# SendGrid (email)
SENDGRID_API_KEY=
ALERT_FROM_EMAIL=alerts@example.com

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Google Docs (service account)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DOC_SHARE_WITH=

# Optional LLM hook
OPENAI_API_KEY=
